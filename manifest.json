{
  "manifestVersion": 5,
  "id": "com.florian-silvester.specimen-indd",
  "name": "Specimen",
  "version": "1.0.0",
  "main": "index.html",
  "host": [
    {
      "app": "ID",
      "minVersion": "17.0.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "specimenPanel",
      "label": {
        "default": "Specimen"
      },
      "minimumSize": { "width": 300, "height": 400 },
      "maximumSize": { "width": 800, "height": 2000 },
      "preferredDockedSize": { "width": 340, "height": 600 }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "request",
    "network": {
      "domains": ["https://*"]
    },
    "ipc": {
      "enablePluginCommunication": true
    }
  }
}
